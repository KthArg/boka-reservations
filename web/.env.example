# Supabase — https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# OnvoPay — https://docs.onvopay.com/
# Sandbox: onvo_test_* | Producción: onvo_live_*
ONVOPAY_SECRET_KEY=onvo_test_<your-key>
ONVOPAY_WEBHOOK_SECRET=<webhook-secret>
NEXT_PUBLIC_ONVOPAY_PUBLIC_KEY=onvo_test_pk_<your-key>

# Email transaccional — ver spec 0007
# - dev/CI: dejar EMAIL_PROVIDER=mailpit. SMTP de Mailpit corre en :54325
#   cuando supabase local esta levantado (ver supabase/config.toml).
# - staging/prod: EMAIL_PROVIDER=resend y RESEND_API_KEY del dashboard de Resend.
EMAIL_PROVIDER=mailpit
EMAIL_FROM=Boka Trails <no-reply@localhost>
RESEND_API_KEY=re_<your-key>
SMTP_HOST=127.0.0.1
SMTP_PORT=54325
NOTIFICATIONS_ENABLED=true

# URL pública del sitio (para magic links y redirects)
APP_URL=http://localhost:3000

# Solo dev detrás de un proxy (ngrok): host público para permitir Server Actions
# desde ese origen. Dejar vacío en local/prod normal. Si se usa, alinear también
# site_url y additional_redirect_urls en supabase/config.toml a esa URL.
# NGROK_HOST=tu-subdominio.ngrok-free.dev

# Sentry — https://sentry.io (opcional, solo se activa en producción)
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=  # solo en CI para subir source maps
