# Supabase — service role key para operaciones del worker
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co

# OnvoPay
ONVOPAY_SECRET_KEY=onvo_test_<your-key>

# Resend
RESEND_API_KEY=re_<your-key>

# URL pública del sitio (para magic links en emails)
APP_URL=http://localhost:3000

NODE_ENV=development

# Sentry — https://sentry.io (opcional, solo se activa en producción)
SENTRY_DSN=
