# Supabase — service role key para operaciones del worker
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co

# OnvoPay
ONVOPAY_SECRET_KEY=onvo_test_<your-key>

# Email transaccional — ver spec 0007
# dev: EMAIL_PROVIDER=mailpit + SMTP_PORT=54325 (Mailpit del supabase local).
# staging/prod: EMAIL_PROVIDER=resend + RESEND_API_KEY.
EMAIL_PROVIDER=mailpit
EMAIL_FROM=Boka Trails <no-reply@localhost>
RESEND_API_KEY=
SMTP_HOST=127.0.0.1
SMTP_PORT=54325
NOTIFICATIONS_ENABLED=true

# Retención de datos / anonimización de PII (spec 0022). Kill-switch del job
# apply-retention. Dejar en true en producción.
RETENTION_ENABLED=true

# URL pública del sitio (para magic links y links en emails)
APP_URL=http://localhost:3000

NODE_ENV=development

# Sentry — https://sentry.io (opcional, solo se activa en producción)
SENTRY_DSN=
