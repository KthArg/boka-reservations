      "esbuild",
      "msw"
    ]
  },
  "devDependencies": {
    "@faker-js/faker": "^9.8.0",
    "@types/node": "^20",
    "eslint": "^9",
    "msw": "^2.7.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.2.3"
  }
}
